{
  "_comment": "ATLAS settings template. Copy to settings.json (gitignored) and edit. Both the Owner (via Settings UI) and the AGE edit the real settings.json. Every L3 setting maps here.",
  "version": "0.1.0",
  "general": {
    "owner_name": "Owner",
    "timezone": "auto",
    "language": "en"
  },
  "onboarding": {
    "completed": false,
    "identity_approved": false,
    "privacy_acknowledged": false
  },
  "voice": {
    "wake_word_enabled": true,
    "wake_word_model": "hey_jarvis",
    "wake_word_sensitivity": 0.6,
    "vad_silence_ms": 700,
    "stt_model": "base.en",
    "tts_voice": "kokoro:bm_george",
    "speech_rate": 1.0,
    "streaming_tts": true,
    "mic_mute": false
  },
  "model": {
    "mode": "api",
    "backend": "claude-sonnet-4-6",
    "escalation_model": "claude-opus-4-8",
    "fallback_chain": ["claude-sonnet-4-6", "local-gemma", "offline"],
    "api_key_ref": "keychain:atlas-anthropic-api-key",
    "api_key_env": "ANTHROPIC_API_KEY",
    "max_tokens": 8192,
    "temperature": 0.4,
    "openrouter": {
      "endpoint": "https://openrouter.ai/api/v1",
      "model": "openai/gpt-5-mini",
      "api_key_ref": "keychain:atlas-openrouter-api-key",
      "api_key_env": "OPENROUTER_API_KEY"
    },
    "local": {
      "endpoint": "http://localhost:8080/v1",
      "model": "lmstudio-community/gemma-4-26B-A4B-it-QAT-MLX-4bit"
    },
    "routing": {
      "enabled": false,
      "tiers": {
        "code":    { "provider": "openrouter", "model": "anthropic/claude-opus-4.8" },
        "complex": { "provider": "openrouter", "model": "anthropic/claude-sonnet-4.6" },
        "daily":   { "provider": "openrouter", "model": "openai/gpt-oss-120b:free" }
      }
    }
  },
  "memory": {
    "vault_path": "atlas/memory/vault",
    "episodic_path": "atlas/memory/episodic",
    "index_db": "atlas/memory/index.db",
    "retrieval_top_k": 6,
    "history_turns": 8,
    "decay_days": 30,
    "consolidation_time": "03:00",
    "memory_writing_paused": false
  },
  "upgrade": {
    "approval_level": "PATCH_only",
    "cycle_schedule": "nightly@03:00",
    "meta_recursion_every_n_cycles": 10,
    "auto_apply": false,
    "auto_restart": true
  },
  "connectors": {
    "registry_path": "atlas/connectors/registry.json"
  },
  "web": {
    "provider": "duckduckgo",
    "max_results": 5,
    "api_key_ref": "keychain:atlas-search-api-key"
  },
  "scheduler": {
    "enabled": true,
    "check_interval_seconds": 60,
    "jobs": {
      "consolidate":   { "handler": "consolidate",   "type": "daily", "at": "03:00", "enabled": true, "risk": "WRITE", "catch_up": false },
      "health_report": { "handler": "health_report", "type": "daily", "at": "23:55", "enabled": true, "risk": "READ", "catch_up": false },
      "episodic_purge":{ "handler": "episodic_purge","type": "daily", "at": "04:00", "enabled": true, "risk": "DESTRUCTIVE", "catch_up": false },
      "upgrade_cycle": { "handler": "upgrade_cycle", "type": "daily", "at": "03:30", "enabled": true, "risk": "WRITE", "catch_up": false }
    }
  },
  "privacy": {
    "episodic_retention_days": 90,
    "encrypt_at_rest": true,
    "secrets_store": "macos_keychain",
    "third_party_pii_retention_days": 90
  },
  "ui": {
    "theme": "dark_futuristic",
    "accent": "#00e0ff",
    "port": 8765
  }
}
