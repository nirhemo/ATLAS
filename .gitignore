# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# ATLAS runtime artifacts (derived / local-only)
atlas/memory/index.db
atlas/memory/index.db-*

# Daily event logs are runtime, machine-local
atlas/logs/*.jsonl
atlas/logs/*.log

# Date-named episodic transcripts are runtime data (example.jsonl is committed)
atlas/memory/episodic/[0-9]*.jsonl

# Snapshots of state before MAJOR/MINOR upgrades
atlas/snapshots/*/
!atlas/snapshots/.gitkeep

# Local neural-TTS model files (~335MB, downloaded — see interface/voice/tts.py)
atlas/interface/voice/models/

# Secrets must never be committed (Section 8 — Keychain only)
.env
*.key

# Per-user state — never committed (templates: *.example.* ship in git, the
# loaders fall back to them on a fresh clone). This is also what lets the
# self-updater pull new code without ever touching the owner's data/settings.
atlas/config/settings.json
atlas/connectors/registry.json

# MemVault: live per-user notes are NEVER committed — consolidation and the
# onboarding seed write the owner's personal facts here. Only the directory
# READMEs and *.example.* seed notes are tracked.
atlas/memory/vault/preferences/
atlas/memory/vault/decisions/
atlas/memory/vault/topics/
atlas/memory/vault/people/*.md
!atlas/memory/vault/people/*.example.md

# Local Claude Code session dir
.claude/

# L8 Scheduler runtime state (last_run / next_run per job)
atlas/scheduler/state.json
