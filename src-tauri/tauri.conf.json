{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ATLAS",
  "version": "0.6.0",
  "identifier": "ai.atlas.assistant",
  "build": {
    "frontendDist": "../atlas/interface/web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/atlas-core"],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": "Entitlements.plist"
    },
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" }
    }
  }
}
